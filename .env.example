# Database
DATABASE_URL=./data/the-frame.db

# Auth (NextAuth v5)
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Email (Resend - for magic link auth)
RESEND_API_KEY=

# Shopify (multi-shop OAuth — public app via Custom Distribution)
# Tokens for individual stores live in the shopify_shops table after a
# merchant connects via /settings/integrations/shopify. The values below are
# the app credentials shared by all stores.
SHOPIFY_API_KEY=7a1d1bd5bb328d1928a9e73835ff2726
SHOPIFY_API_SECRET=
# Public base URL where OAuth callbacks land. Match Partners → App URL.
# Local dev: use your ngrok / cloudflared tunnel URL (e.g. https://abc.ngrok-free.app)
# Production: https://theframe.getjaxy.com
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_API_VERSION=2025-07
# Comma-separated. Must match Partners → App scopes exactly.
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers,read_inventory,write_inventory,read_fulfillments,write_fulfillments,read_locations,read_assigned_fulfillment_orders,write_assigned_fulfillment_orders,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders,read_third_party_fulfillment_orders,write_third_party_fulfillment_orders,read_product_listings,read_draft_orders,write_draft_orders,read_price_rules,write_price_rules,read_discounts,write_discounts,read_marketing_events,write_marketing_events,read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,read_content,write_content,read_themes,write_themes,read_translations,write_translations,read_files,write_files,read_shipping,write_shipping,read_returns,write_returns,read_publications,write_publications,read_online_store_pages,write_online_store_pages,read_online_store_navigation,write_online_store_navigation,read_resource_feedbacks,write_resource_feedbacks,read_script_tags,write_script_tags,read_shopify_payments_disputes,read_locales,read_gift_cards,write_gift_cards,read_companies,write_companies,read_purchase_options,write_purchase_options,read_validations,read_order_edits,write_order_edits,read_custom_fulfillment_services,write_custom_fulfillment_services,read_checkouts

# Faire
FAIRE_API_KEY=

# Instantly
INSTANTLY_API_KEY=

# Outscraper
OUTSCRAPER_API_KEY=

# Xero
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Klaviyo
KLAVIYO_API_KEY=

# Telegram (for alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
# Shopify webhook signing — public apps verify via SHOPIFY_API_SECRET above,
# so this var is no longer needed. Keep blank or remove from .env.local.
SHOPIFY_WEBHOOK_SECRET=
